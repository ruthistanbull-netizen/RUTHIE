PORT=8787

# Panel login
RUTH_ADMIN_USER=ruth
RUTH_ADMIN_PASSWORD=change-this-password
RUTH_SESSION_SECRET=change-this-long-random-secret

# Optional persistent file path when using Render persistent disk
RUTH_DATA_DIR=./data

# Recommended persistent database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Push notifications for iPhone/PC PWA
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@ruthistanbul.com

# Customer image limit, stored as data URL in v1
RUTH_MAX_IMAGE_BYTES=2500000
